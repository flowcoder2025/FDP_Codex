# Design fixture only. Codex does not auto-load this path, and it is not runtime enforcement.

prefix_rule(
    pattern = [["codex", "codex.exe", "codex.cmd", "codex.ps1"]],
    decision = "forbidden",
    justification = "Nested Codex execution is forbidden inside a managed worker.",
)

prefix_rule(
    pattern = [["node", "node.exe", "npx", "npx.cmd", "npm", "npm.cmd", "pnpm", "pnpm.cmd", "bun", "bun.exe", "bunx", "bunx.exe", "yarn", "yarn.cmd", "corepack", "corepack.exe"]],
    decision = "forbidden",
    justification = "Runtime and package-manager execution belongs to the visible controller.",
)

prefix_rule(
    pattern = [["powershell", "powershell.exe", "pwsh", "pwsh.exe", "cmd", "cmd.exe", "python", "python.exe", "python3", "python3.exe", "py", "py.exe", "bash", "bash.exe", "sh", "sh.exe", "wsl", "wsl.exe"]],
    decision = "forbidden",
    justification = "Shell and script re-entry belongs to the visible controller.",
)
