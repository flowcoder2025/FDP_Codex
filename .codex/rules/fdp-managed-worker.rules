prefix_rule(
    pattern = [["codex", "codex.exe", "codex.cmd", "codex.ps1"]],
    decision = "forbidden",
    justification = "Nested Codex execution is forbidden inside a managed worker. Return control to the visible controller.",
    match = [["codex", "exec"], ["codex.exe", "exec"]],
)

prefix_rule(
    pattern = [["node", "node.exe"]],
    decision = "forbidden",
    justification = "Direct Node execution is forbidden inside a managed worker. Use declared package scripts instead.",
    match = [["node", "tool.js"], ["node.exe", "codex.js", "exec"]],
)

prefix_rule(
    pattern = [["npx", "npx.cmd"]],
    decision = "forbidden",
    justification = "Ad-hoc package execution is forbidden inside a managed worker. Use declared package scripts instead.",
    match = [["npx", "codex"], ["npx.cmd", "@openai/codex"]],
)

prefix_rule(
    pattern = [["npm", "npm.cmd"], ["exec", "x"]],
    decision = "forbidden",
    justification = "Ad-hoc npm package execution is forbidden inside a managed worker. Use npm run with declared scripts instead.",
    match = [["npm", "exec", "codex"], ["npm.cmd", "x", "@openai/codex"]],
)

prefix_rule(
    pattern = [["pnpm", "pnpm.cmd"], ["dlx", "exec"]],
    decision = "forbidden",
    justification = "Ad-hoc pnpm package execution is forbidden inside a managed worker. Use declared package scripts instead.",
    match = [["pnpm", "dlx", "codex"], ["pnpm.cmd", "exec", "@openai/codex"]],
)

prefix_rule(
    pattern = [["bun", "bun.exe", "bunx", "bunx.exe"]],
    decision = "forbidden",
    justification = "Ad-hoc Bun execution is forbidden inside a managed worker. Use declared package scripts instead.",
    match = [["bun", "x", "codex"], ["bunx", "@openai/codex"]],
)

prefix_rule(
    pattern = [["powershell", "powershell.exe", "pwsh", "pwsh.exe", "cmd", "cmd.exe"]],
    decision = "forbidden",
    justification = "Nested shell interpreters are forbidden inside a managed worker. Invoke supported commands directly.",
    match = [["powershell.exe", "-Command", "codex exec"], ["cmd.exe", "/c", "codex exec"]],
)

prefix_rule(
    pattern = [["python", "python.exe", "python3", "python3.exe", "py", "py.exe"]],
    decision = "forbidden",
    justification = "Direct Python execution is forbidden inside a managed worker. Use declared package scripts instead.",
    match = [["python.exe", "-c", "import subprocess"], ["py.exe", "tool.py"]],
)

prefix_rule(
    pattern = [["bash", "bash.exe", "sh", "sh.exe", "wsl", "wsl.exe"]],
    decision = "forbidden",
    justification = "Nested Unix shell interpreters are forbidden inside a managed worker. Invoke supported commands directly.",
    match = [["bash", "-c", "codex exec"], ["wsl.exe", "sh", "-c", "codex exec"]],
)
